<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.locationchanger.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/LocationChanger.app/Contents/Helpers/locationchanger</string>
    </array>
    <key>LaunchEvents</key>
    <dict>
        <key>com.apple.notifyd.matching</key>
        <dict>
            <key>com.locationchanger.network-changed</key>
            <dict>
                <key>Notification</key>
                <string>State:/Network/Global/IPv4</string>
            </dict>
        </dict>
    </dict>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>/tmp/locationchanger.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/locationchanger.err.log</string>
</dict>
</plist>
